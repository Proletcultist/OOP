<?xml version = "1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.collections.FXCollections?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>
<?import ru.nsu.zenin.snake.view.GameFieldView?>
<?import ru.nsu.zenin.snake.controller.GameController?>
<?import ru.nsu.zenin.snake.controller.GameController.LevelOption?>
<?import ru.nsu.zenin.snake.controller.GameController.DrawerOption?>
<?import java.lang.String?>

<StackPane xmlns:fx="http://javafx.com/fxml" fx:controller="ru.nsu.zenin.snake.controller.GameController" fx:id = "mainContainer">
    <VBox style="-fx-background-color: #2b2b2b;">
        <HBox style="-fx-background-color: #1c1c1c;" alignment = "CENTER">
            <Text text="Aboba" fill ="#dbdbdb" fx:id = "statusBar">
                <font>
                    <Font size = "20"/>
                </font>
                <HBox.margin>
                    <Insets top = "5" bottom = "5"/>
                </HBox.margin>
            </Text>
        </HBox>
        <GameFieldView VBox.vgrow="ALWAYS" prefWidth="100" prefHeight="100" gridWidth="20" gridHeight="20" fx:id="fieldView"/>
    </VBox>
    <VBox style="-fx-background-color: #3f3f3f;" StackPane.alignment="CENTER" fx:id="modalContainer" spacing="10">
        <VBox fx:id="modalOptionsContainer" spacing="10">
            <TextField promptText = "Grid width" fx:id = "gridWidthInput"/>
            <TextField promptText = "Grid height" fx:id = "gridHeightInput"/>
            <ComboBox editable="false" promptText = "Difficulty" fx:id = "difficultyInput">
                <items>
                    <FXCollections fx:factory="observableArrayList">
                        <GameController.LevelOption fx:value="LEVEL1"/>
                        <GameController.LevelOption fx:value="LEVEL2"/>
                        <GameController.LevelOption fx:value="LEVEL3"/>
                    </FXCollections>
                </items>
            </ComboBox>
            <ComboBox editable="false" promptText = "Drawer" fx:id = "drawerInput">
                <items>
                    <FXCollections fx:factory="observableArrayList">
                        <GameController.DrawerOption fx:value="FANCY"/>
                        <GameController.DrawerOption fx:value="DEBUG"/>
                    </FXCollections>
                </items>
            </ComboBox>
        </VBox>
        <Button text="Play" onAction="#playPressed"/>
    </VBox>
</StackPane>

